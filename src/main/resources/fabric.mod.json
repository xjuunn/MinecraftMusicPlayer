{
  "schemaVersion": 1,
  "id": "musicplayer",
  "version": "${version}",
  "name": "Minecraft Music Player",
  "description": "Client-assisted music playback for Fabric servers with NetEase search, queue and vote skip.",
  "authors": [
    "junhsiun"
  ],
  "contact": {
    "sources": "https://github.com/junhsiun/MinecraftMusicPlayer"
  },
  "license": "MIT",
  "icon": "assets/musicplayer/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.junhsiun.musicplayer.MusicPlayerMod"
    ],
    "client": [
      "com.junhsiun.musicplayer.MusicPlayerClientMod"
    ]
  },
  "mixins": [
    "musicplayer.client.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=21",
    "fabric-api": ">=${fabric_api_version}"
  }
}
